{
    "private": true,
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "clean": "turbo run clean && rm -rf node_modules",
        "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
        "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
        "generate-dataset": "bun scripts/generate-dataset.ts",
        "index-docs": "bun scripts/index-docs.ts",
        "augment-dataset": "bun scripts/augment-dataset.ts",
        "augment-dataset:dry": "bun scripts/augment-dataset.ts --dry-run",
        "extract-pdf-qa": "bun scripts/extract-pdf-qa.ts",
        "extract-pdf-qa:dry": "bun scripts/extract-pdf-qa.ts --dry-run",
        "split-dataset": "bun scripts/split-dataset.ts",
        "finetune": "bash scripts/finetune.sh",
        "finetune:dry": "bash scripts/finetune.sh --dry-run",
        "setup-finetune": "bash scripts/setup-finetune.sh",
        "eval-model": "bun scripts/eval-model.ts",
        "eval-model:baseline": "OLLAMA_MODEL=mistral:7b-instruct bun scripts/eval-model.ts --limit 20",
        "eval-model:finetuned": "OLLAMA_MODEL=iris-mistral bun scripts/eval-model.ts --limit 20",
        "scrape-sources": "bun scripts/scrape-sources.ts",
        "scrape-sources:dry": "bun scripts/scrape-sources.ts --dry-run",
        "extract-web-qa": "bun scripts/extract-web-qa.ts",
        "extract-web-qa:dry": "bun scripts/extract-web-qa.ts --dry-run",
        "scrape-stj": "bun scripts/scrape-stj-datasets.ts",
        "build-full-dataset": "bun scripts/build-full-dataset.ts",
        "build-full-dataset:dry": "bun scripts/build-full-dataset.ts --dry-run",
        "build-full-dataset:no-augment": "bun scripts/build-full-dataset.ts --skip-augment",
        "build-full-dataset:skip-scrape": "bun scripts/build-full-dataset.ts --skip-scrape"
    },
    "devDependencies": {
        "@typescript-eslint/parser": "^8.25.0",
        "eslint": "^9.21.0",
        "eslint-plugin-prettier": "^5.2.3",
        "globals": "^16.0.0",
        "prettier": "^3.2.5",
        "prettier-plugin-tailwindcss": "^0.5.12",
        "tsconfig-paths-webpack-plugin": "^4.2.0",
        "turbo": "latest"
    },
    "overrides": {
        "csstype": "3.2.3",
        "@ai-sdk/provider": "1.0.12",
        "langfuse-core": "3.38.20"
    },
    "packageManager": "bun@1.3.14",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "dependencies": {
        "@anthropic-ai/sdk": "^0.52.0",
        "@mozilla/readability": "^0.6.0",
        "@typescript-eslint/eslint-plugin": "^8.25.0",
        "@vercel/functions": "^2.0.0",
        "ai": "^2.2.0",
        "date-fns": "^4.1.0",
        "node-html-parser": "^7.0.1",
        "react-intersection-observer": "^9.16.0",
        "remark-slug": "^8.0.0",
        "turndown": "^7.2.0"
    }
}
